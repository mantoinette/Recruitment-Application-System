# Copy to .env and adjust for your machine:
#   copy .env.example .env

# --- PostgreSQL (local via Docker) ---
# From repo root run: docker compose up -d postgres
# Use host + credentials separately (do NOT put user:pass inside the URL)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5434/recruitment_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_password_here

# --- Server ---
PORT=8080

# --- CORS (frontend URLs, comma-separated) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173

# --- Render (use ONE of these approaches) ---
# Option A: link Postgres on Render and use:
# DATABASE_URL=postgresql://user:pass@host/dbname
#
# Option B: set JDBC URL manually:
# SPRING_DATASOURCE_URL=jdbc:postgresql://HOST:5432/DBNAME?sslmode=require
# SPRING_DATASOURCE_USERNAME=your_user
# SPRING_DATASOURCE_PASSWORD=your_password
# CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com

# --- Email (optional — leave blank to use in-app notifications only) ---
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=your-email@gmail.com
# SPRING_MAIL_PASSWORD=your-app-password
